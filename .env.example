# ============================================================
# claude-remote-bot — Environment Configuration
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ============================================================

# ----- Telegram -----
TELEGRAM_BOT_TOKEN=your_bot_token_here
ADMIN_TELEGRAM_ID=your_telegram_user_id

# ----- Anthropic -----
# Optional — if set, SDK uses this key. Otherwise falls back to CLI auth.
ANTHROPIC_API_KEY=

# ----- Claude Behaviour -----
CLAUDE_MODEL=
CLAUDE_MAX_TURNS=10
CLAUDE_TIMEOUT_SECONDS=120
CLAUDE_MAX_COST_PER_USER=5.0
CLAUDE_MAX_COST_PER_REQUEST=1.0

# ----- Storage -----
DATABASE_URL=sqlite:///data/bot.db
SESSION_TIMEOUT_HOURS=24

# ----- Rate Limiting -----
RATE_LIMIT_CLAUDE_PER_MIN=20
RATE_LIMIT_COMMANDS_PER_MIN=5
RATE_LIMIT_INVITES_PER_HOUR=3

# ----- SSH Tunnel (ngrok) -----
# Set to enable tunnel management
NGROK_AUTHTOKEN=
SSH_PORT=22
TUNNEL_POLL_INTERVAL_SECONDS=30
TUNNEL_MAX_RETRIES=5

# ----- System Monitor -----
MONITOR_ENABLED=true
MONITOR_COLLECT_INTERVAL_SECONDS=60
HOURLY_REPORT_ENABLED=false

# CPU/RAM/Disk alert thresholds
ALERT_CPU_PERCENT=90
ALERT_RAM_PERCENT=85
ALERT_DISK_PERCENT=90
ALERT_SSH_FAILURES_PER_MIN=5

# ----- Bot Behaviour -----
LOG_LEVEL=INFO
DEBUG=false
AGENTIC_MODE=true

# ----- Feature Flags -----
ENABLE_TUNNEL=false
ENABLE_MONITOR=true
ENABLE_API_SERVER=false
API_SERVER_PORT=8080
ENABLE_VOICE_MESSAGES=false
ENABLE_FILE_UPLOADS=true
ENABLE_GIT_INTEGRATION=true
